{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main",
    "detached-*"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "core:webview:allow-create-webview-window",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*" },
        { "url": "https://*" }
      ]
    }
  ]
}